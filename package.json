{
  "name": "z-claw",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --filter z-claw-desktop dev",
    "build": "pnpm --filter z-claw-desktop build",
    "preview": "pnpm --filter z-claw-desktop preview",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "format": "prettier --write \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\"",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "openspec": "openspec",
    "sync-skills": "node scripts/sync_skills.mjs"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.3.1",
    "@tauri-apps/cli": "^2.11.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "5.9.3"
  }
}
